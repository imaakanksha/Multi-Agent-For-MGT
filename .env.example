# ============================================================
# Multi-Agent Research Report Generator - Environment Config
# ============================================================
# This project supports TWO deployment modes:
#   Option A: Cloud (OpenAI/Azure) — Paid, higher quality
#   Option B: Local (Ollama/SQLite) — $0 cost, fully offline
#
# For Option B (zero cost), you ONLY need the [LOCAL LLM] section.
# Everything else (storage, queues, search) falls back to SQLite.
# ============================================================

# ============================================================
# OPTION A: Cloud / Azure Stack
# ============================================================

# --- OpenAI / Azure OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_API_BASE=                        # Leave empty for direct OpenAI
# OPENAI_API_BASE=https://your-resource.openai.azure.com/  # Azure OpenAI
OPENAI_MODEL_PLANNING=gpt-4o              # High-capability model for planning
OPENAI_MODEL_EXTRACTION=gpt-4o-mini       # Cost-efficient model for extraction
OPENAI_MODEL_WRITING=gpt-4o              # High-capability model for writing

# --- Web Search ---
TAVILY_API_KEY=tvly-your-tavily-api-key   # Free tier: 1000 searches/month

# --- Azure Storage (State Persistence + Dead-Letter Queue) ---
# Leave empty to use SQLite fallback for local development
AZURE_STORAGE_CONNECTION_STRING=
AZURE_TABLE_NAME=workflowstate
AZURE_DEAD_LETTER_QUEUE=research-dead-letter

# --- Azure Cosmos DB (Optional - LangGraph Checkpointing) ---
AZURE_COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-key
AZURE_COSMOS_DATABASE=research_agent_db
AZURE_COSMOS_CONTAINER=workflow_state

# --- Azure AI Search (Vector Store) ---
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-search-key
AZURE_SEARCH_INDEX=research-documents

# --- Observability ---
LANGSMITH_API_KEY=lsv2-your-langsmith-key
LANGSMITH_PROJECT=multi-agent-research
LANGSMITH_TRACING_V2=true

# ============================================================
# OPTION B: Zero-Cost Local Stack (Ollama + SQLite)
# ============================================================
# Uncomment these lines and comment out the Cloud section above.
#
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL_PLANNING=llama3.1
# OPENAI_MODEL_EXTRACTION=llama3.1
# OPENAI_MODEL_WRITING=llama3.1
#
# Alternative: LM Studio
# OPENAI_API_BASE=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
# OPENAI_MODEL_PLANNING=local-model
# OPENAI_MODEL_EXTRACTION=local-model
# OPENAI_MODEL_WRITING=local-model
#
# Leave all AZURE_* variables empty — SQLite is used automatically.
# Leave TAVILY_API_KEY empty — mock search results are used.
# ============================================================

# --- Workflow Config (same for both options) ---
MAX_SEARCH_RESULTS=10
MAX_RETRIES=3
CONFIDENCE_THRESHOLD=0.7
MAX_REVISION_LOOPS=2
