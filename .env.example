# ============================================================
# Multi-Agent Research Report Generator - Environment Config
# ============================================================

# --- LLM Provider ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL_PLANNING=gpt-4o           # High-capability model for planning
OPENAI_MODEL_EXTRACTION=gpt-4o-mini    # Cost-efficient model for extraction
OPENAI_MODEL_WRITING=gpt-4o            # High-capability model for writing

# --- Web Search ---
TAVILY_API_KEY=tvly-your-tavily-api-key

# --- Azure Storage (State Persistence + Dead-Letter Queue) ---
# Leave empty to use SQLite fallback for local development
AZURE_STORAGE_CONNECTION_STRING=
AZURE_TABLE_NAME=workflowstate
AZURE_DEAD_LETTER_QUEUE=research-dead-letter

# --- Azure Cosmos DB (Optional - LangGraph Checkpointing) ---
AZURE_COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-key
AZURE_COSMOS_DATABASE=research_agent_db
AZURE_COSMOS_CONTAINER=workflow_state

# --- Azure AI Search (Vector Store) ---
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-search-key
AZURE_SEARCH_INDEX=research-documents

# --- Observability ---
LANGSMITH_API_KEY=lsv2-your-langsmith-key
LANGSMITH_PROJECT=multi-agent-research
LANGSMITH_TRACING_V2=true

# --- Workflow Config ---
MAX_SEARCH_RESULTS=10
MAX_RETRIES=3
CONFIDENCE_THRESHOLD=0.7
MAX_REVISION_LOOPS=2
